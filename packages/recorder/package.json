{
    "name": "@page-agent/recorder",
    "private": false,
    "version": "1.8.0",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "default": "./src/index.ts"
        }
    },
    "publishConfig": {
        "main": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "exports": {
            ".": {
                "types": "./dist/index.d.ts",
                "import": "./dist/index.js",
                "default": "./dist/index.js"
            }
        }
    },
    "description": "User operation recorder for page-agent - captures real browser interactions as replayable action lists",
    "author": "Simon<gaomeng1900>",
    "license": "MIT",
    "dependencies": {
        "@page-agent/page-controller": "1.8.0"
    }
}
